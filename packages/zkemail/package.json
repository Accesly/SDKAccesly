{
  "name": "@accesly/zkemail",
  "version": "0.0.0",
  "description": "ZK email recovery prover for Accesly Smart Accounts. Browser client that turns a DKIM-signed .eml into a Groth16 proof verifiable on Soroban.",
  "license": "MIT",
  "author": "Accesly Core <acceslyoficial@gmail.com>",
  "homepage": "https://github.com/Accesly/SDKAccesly#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Accesly/SDKAccesly.git",
    "directory": "packages/zkemail"
  },
  "bugs": {
    "url": "https://github.com/Accesly/SDKAccesly/issues"
  },
  "keywords": [
    "stellar",
    "soroban",
    "zk-email",
    "groth16",
    "bls12-381",
    "recovery",
    "sep-30",
    "accesly"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./eml": {
      "types": "./dist/eml/index.d.ts",
      "import": "./dist/eml/index.js",
      "require": "./dist/eml/index.cjs"
    },
    "./soroban": {
      "types": "./dist/soroban/index.d.ts",
      "import": "./dist/soroban/index.js",
      "require": "./dist/soroban/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/hashes": "^1.6.1"
  },
  "peerDependencies": {
    "snarkjs": "^0.7.0"
  },
  "peerDependenciesMeta": {
    "snarkjs": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "snarkjs": "^0.7.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
