{
  "name": "@accesly/react",
  "version": "1.11.0",
  "description": "Accesly SDK React adapter — AcceslyProvider and useAccesly hook.",
  "license": "MIT",
  "author": "Accesly Core <acceslyoficial@gmail.com>",
  "homepage": "https://github.com/Accesly/SDKAccesly#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Accesly/SDKAccesly.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/Accesly/SDKAccesly/issues"
  },
  "keywords": [
    "stellar",
    "wallet",
    "react",
    "hooks",
    "accesly"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@accesly/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "happy-dom": "^15.11.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
