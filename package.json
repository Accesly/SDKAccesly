{
  "name": "accesly-sdk-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Accesly SDK monorepo — @accesly/core (framework-agnostic) + @accesly/react.",
  "license": "MIT",
  "author": "Accesly Core <acceslyoficial@gmail.com>",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\"",
    "lint:fix": "pnpm run lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,yaml,yml}\"",
    "typecheck": "pnpm -r --parallel run typecheck",
    "build": "pnpm -r --filter=\"./packages/*\" run build",
    "test": "pnpm -r --parallel run test",
    "test:watch": "pnpm -r --parallel run test:watch",
    "audit:no-custody": "node scripts/audit-no-custody.mjs",
    "gen:api-types": "node scripts/gen-api-types.mjs",
    "smoke-test:dev": "node scripts/smoke-test-dev.mjs",
    "clean": "pnpm -r --parallel exec rimraf dist .turbo tsconfig.tsbuildinfo",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm build && changeset publish",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm audit:no-custody && pnpm build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
